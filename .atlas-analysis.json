  "keyFeatures": [
    "Distributed Validator Technology (DVT) using Secret Shared Validators",
    "Byzantine Fault Tolerant consensus with Istanbul BFT (iBFT)",
    "Multi-operator validator management with MPC threshold schemes",
    "P2P networking with libp2p and discovery via discv5",
    "Support for Ethereum consensus layer duties (attestation, proposal, sync committee)",
    "Slashing protection and fault tolerance",
    "Prometheus metrics and monitoring",
    "Docker-based deployment and local development clusters"
  ],
  "publicApiSurface": [
    "start-node - Start an SSV operator node",
    "start-boot-node - Start a bootstrap node for network discovery",
    "generate-operator-keys - Generate operator key pairs",
    "create-threshold - Split validator keys using Shamir Secret Sharing",
    "export-keys - Export validator keys from mnemonic",
    "GET /health - Node health check endpoint",
    "GET /v1/node/identity - Get node identity and public key",
    "GET /v1/node/peers - List connected peers",
    "GET /v1/validators - List managed validators",
    "GET /v1/validators/{pubkey} - Get validator status"
  ]
